<?xml version="1.0" encoding="UTF-8"?>

<?import com.jfoenix.controls.JFXButton?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane fx:id="forgetPasswordPane" prefHeight="466.0" prefWidth="486.0" style="-fx-background-color: white;" xmlns="http://javafx.com/javafx/22" xmlns:fx="http://javafx.com/fxml/1" fx:controller="lk.edu.novelnook.novelnook.controller.auth.PasswordResetController">
   <children>
      <Label layoutX="29.0" layoutY="26.0" text="Novel Nook">
         <font>
            <Font name="Forte" size="42.0" />
         </font>
      </Label>
      <Label layoutX="29.0" layoutY="73.0" text="Forget Password">
         <font>
            <Font name="Segoe UI Bold" size="14.0" />
         </font>
      </Label>
      <ImageView fitHeight="125.0" fitWidth="136.0" layoutX="183.0" layoutY="108.0" pickOnBounds="true" preserveRatio="true">
         <image>
            <Image url="@../../../../../images/logo%20(1).png" />
         </image>
      </ImageView>
      <Label layoutX="72.0" layoutY="249.0" text="Enter Email">
         <font>
            <Font name="Segoe UI Bold" size="12.0" />
         </font>
      </Label>
      <TextField fx:id="emailText" layoutX="72.0" layoutY="270.0" prefHeight="47.0" prefWidth="347.0" promptText="sample123@gmail.com" style="-fx-border-radius: 8; -fx-background-radius: 8; -fx-background-color: #f9fafb; -fx-border-color: #e5e7eb;" />
      <JFXButton layoutX="72.0" layoutY="356.0" onAction="#gotoPasswordVerificationView" prefHeight="47.0" prefWidth="347.0" style="-fx-background-color: #000; -fx-border-radius: 8; -fx-background-radius: 8;" text="Send verification code to my email" textFill="WHITE">
         <font>
            <Font name="Segoe UI Bold" size="14.0" />
         </font>
         <cursor>
            <Cursor fx:constant="HAND" />
         </cursor>
      </JFXButton>
      <ImageView fitHeight="29.0" fitWidth="26.0" layoutX="425.0" layoutY="26.0" onMouseClicked="#backButton" pickOnBounds="true" preserveRatio="true">
         <image>
            <Image url="@../../../../../images/back.png" />
         </image>
         <cursor>
            <Cursor fx:constant="HAND" />
         </cursor>
      </ImageView>
   </children>
</AnchorPane>
